\mymod_if_book:T
{
%内部辅助函数：高亮正确答案 (Book 模式)
\cs_new_protected:Nn \__CQ_highlight_book_answers:
{
  \seq_map_inline:Nn \l_CQ_choices_answer_seq {
    \str_case:nn {##1} {
      {A}{ \tl_put_left:Nn \l_CQ_choices_A_tl {\color{\l_CQ_answer_color_tl}} }
      {B}{ \tl_put_left:Nn \l_CQ_choices_B_tl {\color{\l_CQ_answer_color_tl}} }
      {C}{ \tl_put_left:Nn \l_CQ_choices_C_tl {\color{\l_CQ_answer_color_tl}} }
      {D}{ \tl_put_left:Nn \l_CQ_choices_D_tl {\color{\l_CQ_answer_color_tl}} }
      {E}{ \tl_put_left:Nn \l_CQ_choices_E_tl {\color{\l_CQ_answer_color_tl}} }
      {F}{ \tl_put_left:Nn \l_CQ_choices_F_tl {\color{\l_CQ_answer_color_tl}} }
    }
  }
}

