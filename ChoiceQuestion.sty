%格式声明
\NeedsTeXFormat{LaTeX2e}[2021-11-15]

\RequirePackage{expl3}

\ProvidesExplPackage{ChoiceQuestion}{2026-04-05}{0.1}{选择题}

\RequirePackage{package/exam-zh-choices} %选择题依赖
\RequirePackage{xeCJKfntef} %中文的波浪线、加点、删除线等
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}

\definecolor{AnswerGreen}{HTML}{1A7A5C}    % <--- 优雅翡翠绿
\definecolor{BGAnswer}{HTML}{E8F5EF}       % <--- 极浅绿底色

% 定义变量，选定义，后使用
\tl_new:N   \l_CQ_choices_answer_tl
\tl_new:N   \l_CQ_choices_color_tl
\tl_new:N   \l_CQ_choices_label_pos_tl
\tl_new:N   \l_CQ_choices_A_tl
\tl_new:N   \l_CQ_choices_B_tl
\tl_new:N   \l_CQ_choices_C_tl
\tl_new:N   \l_CQ_choices_D_tl
\tl_new:N   \l_CQ_choices_E_tl
\tl_new:N   \l_CQ_choices_F_tl

\bool_new:N \l_CQ_choices_ispicture_bool
\bool_new:N \l_CQ_isanswershown_bool

\seq_new:N \l_CQ_choices_answer_seq
\tl_new:N \l_CQ_answer_color_tl

% 消息
\msg_new:nnn { CQ_keys_choices } { unknown-key }{Unknown~key~'\l_keys_key_tl'~in~command~options.}


%宏包加载时的选项
\keys_define:nn {CQ_package_load}
{
    %可选输入参数
    answer_shown .bool_set:N = \l_CQ_isanswershown_bool,
    answer_color .tl_set:N = \l_CQ_answer_color_tl,
    % 初始值
    answer_shown .initial:n = false,
    answer_color .initial:n = AnswerGreen,
    % 默认值
    answer_shown .default:n = true,
}

\ProcessKeyOptions[CQ_package_load] %宏包加载时处理传入参数

%选择题相关命令
\keys_define:nn { CQ_keys_choices }
{
    %可选输入参数
    answer .tl_set:N = \l_CQ_choices_answer_tl,
    color .tl_set:N = \l_CQ_choices_color_tl,
    ispicture .bool_set:N = \l_CQ_choices_ispicture_bool,

    %默认值
    ispicture .initial:n = {false},
    answer .initial:n = {Z},
    color .initial:n = {black},
    unknown .code:n = \msg_error:nn { CQ_keys_choices } { unknown-key } %处理未定义的键
}


% ==========================================================
% 定义内部布尔变量用于记录文档类状态
% ==========================================================
\bool_new:N \l__mymod_is_beamer_bool
\bool_new:N \l__mymod_is_book_bool

% ==========================================================
% 识别当前文档类 (核心逻辑)
% ==========================================================
% LaTeX 内核将文档类名存储在 \@ifclassloaded 中
\@ifclassloaded { beamer }
  { \bool_set_true:N \l__mymod_is_beamer_bool }
  {
    \@ifclassloaded { book }
      { \bool_set_true:N \l__mymod_is_book_bool }
      { \iow_term:n { ==>~ Neither~Beamer~nor~Book~class~detected. } }
  }

% ==========================================================
% 创建现代的公共条件判断 API
% ==========================================================
% 使用 \prg_new_conditional:Nnn 生成完整的条件判断命令族
% p (用于逻辑表达式), T (True分支), F (False分支), TF (True/False分支)
% 利用 \prg_new_conditional:Nnn 解释器会自动为你生成 4 个命令。例如：
%   \mymod_if_beamer:T { ... } : 如果是 Beamer，执行大括号内代码
%   \mymod_if_beamer:F { ... } : 如果不是 Beamer，执行大括号内代码
%   \mymod_if_beamer:TF { ... } { ... } : 如果/否则 分支
%   \mymod_if_beamer_p: : 返回布尔逻辑值（用于逻辑表达式组合，如 && 或 ||）

\prg_new_conditional:Nnn \mymod_if_beamer: { p, T, F, TF }
{
  \bool_if:NTF \l__mymod_is_beamer_bool
    { \prg_return_true: }
    { \prg_return_false: }
}

\prg_new_conditional:Nnn \mymod_if_book: { p, T, F, TF }
{
  \bool_if:NTF \l__mymod_is_book_bool
    { \prg_return_true: }
    { \prg_return_false: }
}




