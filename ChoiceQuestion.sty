% 根据环境应用不同样式和功能
% ==========================================================



% ==========================================================
% --- Beamer 专属配置 ---
% ==========================================================
\mymod_if_beamer:T
{
%填空题答案显示
\NewDocumentCommand \tkanswer {m}
{
    \bool_if:NTF{\l_CQ_isanswershown_bool}
    {
      \CJKunderanyline*{0.5ex}{\color{BGAnswer}\rule{2pt}{2.5ex}}{#1}
    }
    {
      \CJKunderline[hidden=true,skip=false,format=\color{AnswerGreen},thickness=1pt]{#1}
    }
}

%选择题答案显示
\NewDocumentCommand \xzanswer {m}
{
    \bool_if:NTF{\l_CQ_isanswershown_bool}
    {
      \only<1>{$(\quad)$}
      \only<2>{$(\;\mathrm{\color{\l_CQ_answer_color_tl}#1}\;)$}
    }
    {$(\quad)$}
}


%在高考题中，还有一类作图题，或连线题，如连接电路图
%第一个参数原图，第二个参数答案
\NewDocumentCommand \drawpicanswer {mm}
{
    \bool_if:NTF{\l_CQ_isanswershown_bool}
    {
      \only<1>{#1}
      \only<2>{#2}
    }
    {#1}
}

%解答题答案显示
\NewDocumentCommand \jdanswer {m}
{
    \bool_if:NTF{\l_CQ_isanswershown_bool}
    {
      \only<1>{\vfill}
      \only<2>{
            % \vfill\vspace*{1em}{\fcolorbox{\l_CQ_answer_color_tl}{\l_CQ_answer_color_tl!10}{\parbox{1\linewidth}{#1}}}\vfil % 简单的方框
            \begin{tcolorbox}[
                enhanced, boxrule=0pt, leftrule=2pt, arc=0pt, outer~arc=0pt,
                left=1mm, right=1mm, top=1.5mm, bottom=1.5mm,
                colback=\l_CQ_answer_color_tl!8, colframe=\l_CQ_answer_color_tl,
                before~upper={ \setlength{\parskip}{0.5em} }
                ]
                {
                    \setlength{\leftmargini}{2em}
                    #1
                }
            \end{tcolorbox}
      }
    }
    {\vfill}
}

%选择题：四选项
\NewDocumentCommand \fourchoices{ O{}mmmm }
{
    \begingroup % to make sure the keys don't act globally

    \keys_set:nn{CQ_keys_choices}{#1}

    \bool_if:NTF{\l_CQ_choices_ispicture_bool}
    { \tl_set:Nn \l_CQ_choices_label_pos_tl {bottom} }
    { \tl_set:Nn \l_CQ_choices_label_pos_tl {top-left} }

    \tl_set:Nn \l_CQ_choices_A_tl {#2}
    \tl_set:Nn \l_CQ_choices_B_tl {#3}
    \tl_set:Nn \l_CQ_choices_C_tl {#4}
    \tl_set:Nn \l_CQ_choices_D_tl {#5}

    \bool_if:NT{\l_CQ_isanswershown_bool}{
        \seq_set_split:NnV \l_CQ_choices_answer_seq {} { \l_CQ_choices_answer_tl } %参数为空逐字分割

        \seq_map_inline:Nn \l_CQ_choices_answer_seq {
            \bool_if:NTF{\l_CQ_choices_ispicture_bool}
            {
                \str_if_eq:nnT{##1}{A}
                {
                    \tl_set:Nn \l_CQ_choices_A_tl {
                      \only<1>{#2}
                      \only<2>{\fcolorbox{\l_CQ_answer_color_tl}{\l_CQ_answer_color_tl!10}{#2}}
                    }
                }
                \str_if_eq:nnT{##1}{B}
                {
                    \tl_set:Nn \l_CQ_choices_B_tl {
                      \only<1>{#3}
                      \only<2>{\fcolorbox{\l_CQ_answer_color_tl}{\l_CQ_answer_color_tl!10}{#3}}
                    }
                }
                \str_if_eq:nnT{##1}{C}
                {
                    \tl_set:Nn \l_CQ_choices_C_tl {
                      \only<1>{#4}
                      \only<2>{\fcolorbox{\l_CQ_answer_color_tl}{\l_CQ_answer_color_tl!10}{#4}}
                    }
                }
                \str_if_eq:nnT{##1}{D}
                {
                    \tl_set:Nn \l_CQ_choices_D_tl {
                      \only<1>{#5}
                      \only<2>{\fcolorbox{\l_CQ_answer_color_tl}{\l_CQ_answer_color_tl!10}{#5}}
                    }
                }
            }
            {
                \str_if_eq:nnT{##1}{A}
                {
                    \tl_put_left:Nn \l_CQ_choices_A_tl {\only<2>{\color{\l_CQ_answer_color_tl}}}
                }
                \str_if_eq:nnT{##1}{B}
                {
                    \tl_put_left:Nn \l_CQ_choices_B_tl {\only<2>{\color{\l_CQ_answer_color_tl}}}
                }
                \str_if_eq:nnT{##1}{C}
                {
                    \tl_put_left:Nn \l_CQ_choices_C_tl {\only<2>{\color{\l_CQ_answer_color_tl}}}
                }
                \str_if_eq:nnT{##1}{D}
                {
                    \tl_put_left:Nn \l_CQ_choices_D_tl {\only<2>{\color{\l_CQ_answer_color_tl}}}
                }
            }
        }
    }
    \use:e{\exp_not:N\begin{choices}[label-pos=\l_CQ_choices_label_pos_tl,top-sep=3pt,linesep={0.5ex~plus~0.5ex~minus~0.2ex}]}
    \item \l_CQ_choices_A_tl
    \item \l_CQ_choices_B_tl
    \item \l_CQ_choices_C_tl
    \item \l_CQ_choices_D_tl
    \end{choices}

    \endgroup
}

}








% ==========================================================
% --- Book 专属配置 ---
